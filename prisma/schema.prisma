generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
	moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

enum UserGroup {
    DEFAULT
    PRO
	GOVERNMENT
    ADMIN
}

model User {
    id        Int      @id @default(autoincrement())
    name      String
    email     String   @unique
    password  String
    image     String?
    latitude  Decimal? @db.Decimal(10, 7)
    longitude Decimal? @db.Decimal(10, 7)
	group UserGroup @default(DEFAULT)
    refreshToken String?

	createdAt   DateTime  @default(now())
	modifiedAt  DateTime  @updatedAt
	deletedAt   DateTime?
}
